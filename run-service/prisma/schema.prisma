generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model runs {
  run_id          String     @id @default(uuid()) @db.VarChar(36)
  run_category_id String     @db.VarChar(36)
  user_id         String     @db.VarChar(36)
  vod_url         String     @db.VarChar(255)
  run_duration    BigInt
  submitted_at    DateTime
  verified_at     DateTime?
  status          String     @default("PENDING") @db.VarChar(25)
  comments        comments[]
}

model comments {
  comment_id String   @id @default(uuid()) @db.VarChar(36)
  run_id     String   @db.VarChar(36)
  user_id    String   @db.VarChar(36)
  comment    String   @db.VarChar(255)
  created_at DateTime
  run        runs     @relation(fields: [run_id], references: [run_id])
}
